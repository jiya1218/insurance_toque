generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique
  fullName      String
  roleId        String?  @db.Uuid
  isActive              Boolean  @default(true)
  expoPushToken         String?
  
  // Onboarding Fields
  highestQualification  String?
  dateOfBirth           DateTime?
  joiningDate           DateTime?
  personalMobile        String?
  homeMobile            String?
  
  createdAt             DateTime @default(now())
  updatedAt     DateTime @updatedAt

  role          Role?         @relation(fields: [roleId], references: [id])
  permissions   Permission[]  @relation("UserPermissions")
  assignedLeads Lead[]        @relation("AssignedLeads")
  createdQuotes Quotation[]
  activityLogs  ActivityLog[]
  calls         Call[]
  followUps     FollowUp[]
  claims        Claim[]
  transactions  Transaction[]
  loans         Loan[]
  rtoWork       RTOWork[]
  fitnessWork   FitnessWork[]
  visits        Visit[]
  documents     Document[]
  notifications Notification[]
  dataChanges   DataChangeRequest[] @relation("RequestedBy")
  reviewedChanges DataChangeRequest[] @relation("ReviewedBy")
  leadAssignments LeadAssignment[]
  whatsappLogs    LeadWhatsAppLog[]
  statusHistories LeadStatusHistory[]
  attendance      Attendance[]
  leaveRequests   LeaveRequest[]  @relation("LeaveRequests")
  leaveApprovals  LeaveRequest[]  @relation("LeaveApprovals")
  salaries        Salary[]

  @@map("users")
}

model Role {
  id          String       @id @default(uuid()) @db.Uuid
  name        String       @unique
  description String?
  permissions Permission[] @relation("RolePermissions")
  users       User[]

  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @unique
  description String?
  roles       Role[]  @relation("RolePermissions")
  users       User[]  @relation("UserPermissions")

  @@map("permissions")
}

model Lead {
  id          String   @id @default(uuid()) @db.Uuid
  assignedTo  String?  @db.Uuid
  clientName  String
  clientEmail String?
  clientPhone String?
  status      String   @default("New")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignee    User?         @relation("AssignedLeads", fields: [assignedTo], references: [id])
  policies    Policy[]
  quotations  Quotation[]
  calls       Call[]
  followUps   FollowUp[]
  claims      Claim[]
  loans       Loan[]
  rtoWork     RTOWork[]
  fitnessWork FitnessWork[]
  visits      Visit[]
  
  // New Workflow Fields
  vehicleNo       String?
  expiryDate      DateTime?
  registrationDate DateTime?
  gvw             String?
  address         String?
  messageTemplate String?
  existingAgent   String?
  city            String?

  assignments     LeadAssignment[]
  whatsappLogs    LeadWhatsAppLog[]
  statusHistories LeadStatusHistory[]

  @@index([status])
  @@index([assignedTo])
  @@index([clientPhone])
  @@index([clientEmail])
  @@map("leads")
}

model Policy {
  id            String   @id @default(uuid()) @db.Uuid
  leadId        String?  @db.Uuid
  policyNumber  String   @unique
  provider      String
  type          String
  premiumAmount Decimal  @db.Decimal(12, 2)
  status        String   @default("Active")
  startDate     DateTime
  endDate       DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lead         Lead?         @relation(fields: [leadId], references: [id])
  claims       Claim[]
  transactions Transaction[]

  @@index([status])
  @@index([endDate])
  @@map("policies")
}

model Quotation {
  id        String   @id @default(uuid()) @db.Uuid
  leadId    String?  @db.Uuid
  createdBy String?  @db.Uuid
  amount    Decimal  @db.Decimal(12, 2)
  status    String   @default("Draft")
  details   Json?
  shareToken String? @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lead    Lead? @relation(fields: [leadId], references: [id])
  creator User? @relation(fields: [createdBy], references: [id])

  @@map("quotations")
}

model Call {
  id        String   @id @default(uuid()) @db.Uuid
  leadId    String   @db.Uuid
  userId    String   @db.Uuid
  type      String   @default("outbound")
  outcome   String
  duration  Int?
  notes     String?
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@map("calls")
}

model FollowUp {
  id          String    @id @default(uuid()) @db.Uuid
  leadId      String    @db.Uuid
  assignedTo  String?   @db.Uuid
  leadName    String?
  type        String    @default("call")
  scheduledAt DateTime
  notes       String?
  status      String    @default("pending")
  isOverdue   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  lead     Lead  @relation(fields: [leadId], references: [id])
  assignee User? @relation(fields: [assignedTo], references: [id])

  @@index([status])
  @@index([scheduledAt])
  @@map("follow_ups")
}

model Claim {
  id             String    @id @default(uuid()) @db.Uuid
  policyId       String?   @db.Uuid
  leadId         String?   @db.Uuid
  assignedTo     String?   @db.Uuid
  customerName   String
  policyNumber   String?
  vehicleNumber  String?
  claimType      String?
  claimAmount    Decimal?  @db.Decimal(12, 2)
  approvedAmount Decimal?  @db.Decimal(12, 2)
  status         String    @default("filed")
  incidentDate   DateTime?
  filedDate      DateTime  @default(now())
  settledDate    DateTime?
  description    String?
  documents      Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  policy   Policy? @relation(fields: [policyId], references: [id])
  lead     Lead?   @relation(fields: [leadId], references: [id])
  assignee User?   @relation(fields: [assignedTo], references: [id])

  @@index([status])
  @@map("claims")
}

model Transaction {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String?  @db.Uuid
  leadId          String?  @db.Uuid
  policyId        String?  @db.Uuid
  type            String
  category        String?
  amount          Decimal  @db.Decimal(12, 2)
  status          String   @default("completed")
  paymentMethod   String?
  referenceNumber String?
  description     String?
  date            DateTime @default(now())
  createdAt       DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id])
  policy Policy? @relation(fields: [policyId], references: [id])

  @@index([type])
  @@map("transactions")
}

model Loan {
  id               String    @id @default(uuid()) @db.Uuid
  leadId           String?   @db.Uuid
  assignedTo       String?   @db.Uuid
  customerName     String
  loanType         String?
  amount           Decimal   @db.Decimal(12, 2)
  tenureMonths     Int?
  interestRate     Decimal?  @db.Decimal(5, 2)
  status           String    @default("applied")
  
  // Conversion Tracking
  conversionStatus String    @default("Applied") // Applied, Processing, Approved, Disbursed, Rejected
  
  bankName         String?
  disbursementDate DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  lead     Lead? @relation(fields: [leadId], references: [id])
  assignee User? @relation(fields: [assignedTo], references: [id])

  @@index([status])
  @@map("loans")
}

model RTOWork {
  id             String    @id @default(uuid()) @db.Uuid
  leadId         String?   @db.Uuid
  assignedTo     String?   @db.Uuid
  customerName   String
  vehicleNumber  String?
  workType       String
  status         String    @default("pending")
  rtoOffice      String?
  fees           Decimal?  @db.Decimal(12, 2)
  
  // Payment Tracking
  paymentStatus  String    @default("Pending") // Pending, Paid
  paymentAmount  Decimal?  @db.Decimal(12, 2)
  paymentDate    DateTime?
  
  dueDate        DateTime?
  completionDate DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  lead     Lead? @relation(fields: [leadId], references: [id])
  assignee User? @relation(fields: [assignedTo], references: [id])

  @@map("rto_work")
}

model FitnessWork {
  id            String    @id @default(uuid()) @db.Uuid
  leadId        String?   @db.Uuid
  assignedTo    String?   @db.Uuid
  customerName  String
  vehicleNumber String
  status        String    @default("pending")
  testDate      DateTime?
  expiryDate    DateTime?
  fees          Decimal?  @db.Decimal(12, 2)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  lead     Lead? @relation(fields: [leadId], references: [id])
  assignee User? @relation(fields: [assignedTo], references: [id])

  @@map("fitness_work")
}

model ActivityLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @db.Uuid
  action     String
  entityType String
  entityId   String   @db.Uuid
  metadata   Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([action])
  @@map("activity_logs")
}

model Document {
  id         String   @id @default(uuid()) @db.Uuid
  entityType String
  entityId   String   @db.Uuid
  fileName   String
  filePath   String
  uploadedBy String?  @db.Uuid
  createdAt  DateTime @default(now())

  user User? @relation(fields: [uploadedBy], references: [id])

  @@index([entityType, entityId])
  @@map("documents")
}

model Customer {
  id            String   @id @default(uuid()) @db.Uuid
  leadId        String?  @db.Uuid
  name          String
  phone         String
  email         String?
  address       String?
  kycStatus     String   @default("pending")

  // Revenue Tracking
  totalRevenue  Decimal? @db.Decimal(12, 2)
  lastSaleDate  DateTime?
  policyCount   Int      @default(0)
  loanCount     Int      @default(0)
  claimCount    Int      @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  visits        Visit[]

  @@index([phone])
  @@index([email])
  @@map("customers")
}

model Visit {
  id          String    @id @default(uuid()) @db.Uuid
  customerId  String?   @db.Uuid
  leadId      String?   @db.Uuid
  userId      String?   @db.Uuid
  purpose     String
  scheduledAt DateTime
  completedAt DateTime?
  status      String    @default("scheduled")
  location    String?

  // GPS Tracking
  startLat    Float?
  startLng    Float?
  endLat      Float?
  endLng      Float?
  distanceKm  Float?
  checkInTime DateTime?
  checkOutTime DateTime?
  gpsTrail    Json?     // Array of {lat, lng, timestamp} waypoints

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id])
  lead     Lead?     @relation(fields: [leadId], references: [id])
  user     User?     @relation(fields: [userId], references: [id])

  @@map("visits")
}

model Notification {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  title      String
  body       String
  type       String   @default("info") // info, success, warning, error, action
  entityType String?
  entityId   String?
  isRead     Boolean  @default(false)
  readAt     DateTime?
  data       Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model DataChangeRequest {
  id           String    @id @default(uuid()) @db.Uuid
  requestedBy  String    @db.Uuid
  reviewedBy   String?   @db.Uuid
  entityType   String
  entityId     String    @db.Uuid
  field        String
  oldValue     String?
  newValue     String
  reason       String?
  status       String    @default("pending")
  reviewNote   String?
  requestedAt  DateTime  @default(now())
  reviewedAt   DateTime?

  requester User  @relation("RequestedBy", fields: [requestedBy], references: [id])
  reviewer  User? @relation("ReviewedBy", fields: [reviewedBy], references: [id])

  @@index([status])
  @@index([entityType, entityId])
  @@map("data_change_requests")
}

model LeadAssignment {
  id         String   @id @default(uuid()) @db.Uuid
  leadId     String   @db.Uuid
  userId     String   @db.Uuid
  assignedAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("lead_assignments")
}

model LeadWhatsAppLog {
  id        String   @id @default(uuid()) @db.Uuid
  leadId    String   @db.Uuid
  userId    String   @db.Uuid
  sentAt    DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("lead_whatsapp_logs")
}

model LeadStatusHistory {
  id        String   @id @default(uuid()) @db.Uuid
  leadId    String   @db.Uuid
  userId    String   @db.Uuid
  oldStatus String?
  newStatus String
  notes     String?
  changedAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("lead_status_history")
}

model PredefinedResponse {
  id               String   @id @default(uuid()) @db.Uuid
  text             String   @unique
  isActive         Boolean  @default(true)
  orderIndex       Int      @default(0)
  requiresFollowUp Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("predefined_responses")
}

// ── HR Module ──────────────────────────────────────────────────────────────

model Attendance {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid
  date         DateTime  @db.Date
  checkInTime  DateTime?
  checkOutTime DateTime?
  status       String    @default("present") // present | absent | half_day | late
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User      @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@map("attendance")
}

model LeaveRequest {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  type        String   // sick | casual | earned | unpaid
  startDate   DateTime @db.Date
  endDate     DateTime @db.Date
  days        Int      @default(1)
  reason      String?
  status      String   @default("pending") // pending | approved | rejected
  approvedBy  String?  @db.Uuid
  approvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation("LeaveRequests", fields: [userId], references: [id])
  approver    User?    @relation("LeaveApprovals", fields: [approvedBy], references: [id])

  @@map("leave_requests")
}

model Salary {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  month       Int
  year        Int
  baseAmount  Float    @default(0)
  deductions  Float    @default(0)
  netAmount   Float    @default(0)
  status      String   @default("Pending") // Pending | Paid
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])

  @@unique([userId, month, year])
  @@map("salaries")
}

// ── Rate Calculator ────────────────────────────────────────────────────────

model RateTable {
  id          String     @id @default(uuid()) @db.Uuid
  provider    String
  vehicleType String
  basePremium Float      @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  rules       RateRule[]

  @@map("rate_tables")
}

model RateRule {
  id            String   @id @default(uuid()) @db.Uuid
  rateTableId   String   @db.Uuid
  condition     String   // JSON rule condition
  modifierType  String   // percentage_discount | flat_add | etc
  modifierValue Float    @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  rateTable     RateTable @relation(fields: [rateTableId], references: [id])

  @@map("rate_rules")
}

model Addon {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  priceType   String   @default("flat") // flat | percentage
  priceValue  Float    @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("addons")
}
